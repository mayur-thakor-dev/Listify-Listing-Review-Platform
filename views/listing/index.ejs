<% layout("/layouts/boilerplate.ejs") %>
<% const selectedCategory = filters && filters.category ? filters.category : "all"; %>
<% const selectedSort = filters && filters.sort ? filters.sort : ""; %>
<% const searchValue = filters && filters.q ? filters.q : ""; %>
<% const minValue = filters && filters.minPrice ? filters.minPrice : ""; %>
<% const maxValue = filters && filters.maxPrice ? filters.maxPrice : ""; %>

<section class="explore-header">
    <div>
        <p class="section-kicker">Explore stays</p>
        <h1>Find places that fit your trip</h1>
    </div>
    <a href="/listings/new" class="btn btn-dark">
        <i class="fa-solid fa-plus"></i>
        Add Listing
    </a>
</section>

<section class="listing-toolbar">
    <form method="GET" action="/listings" class="filter-form">
        <div class="filter-field filter-search">
            <label for="q">Destination</label>
            <input type="search" name="q" id="q" value="<%= searchValue %>" placeholder="Search city, stay, category">
        </div>

        <div class="filter-field">
            <label for="category">Category</label>
            <select name="category" id="category">
                <% const categories = [
                    ["all", "All"],
                    ["rooms", "Rooms"],
                    ["hotel", "Hotel"],
                    ["house", "House"],
                    ["resturant", "Restaurant"],
                    ["mountains", "Mountains"],
                    ["iconic cities", "Iconic Cities"],
                    ["castles", "Castles"],
                    ["amazing pool", "Pool"],
                    ["camping", "Camping"],
                    ["farms", "Farms"],
                    ["arctic", "Arctic"],
                    ["domes", "Domes"],
                    ["ships", "Ships"],
                    ["others", "Others"]
                ]; %>
                <% for (let item of categories) { %>
                    <option value="<%= item[0] %>" <%= selectedCategory === item[0] ? "selected" : "" %>>
                        <%= item[1] %>
                    </option>
                <% } %>
            </select>
        </div>

        <div class="filter-field compact">
            <label for="minPrice">Min</label>
            <input type="number" name="minPrice" id="minPrice" value="<%= minValue %>" min="0" placeholder="₹">
        </div>

        <div class="filter-field compact">
            <label for="maxPrice">Max</label>
            <input type="number" name="maxPrice" id="maxPrice" value="<%= maxValue %>" min="0" placeholder="₹">
        </div>

        <div class="filter-field">
            <label for="sort">Sort</label>
            <select name="sort" id="sort">
                <option value="" <%= selectedSort === "" ? "selected" : "" %>>Recommended</option>
                <option value="price-asc" <%= selectedSort === "price-asc" ? "selected" : "" %>>Price low to high</option>
                <option value="price-desc" <%= selectedSort === "price-desc" ? "selected" : "" %>>Price high to low</option>
                <option value="newest" <%= selectedSort === "newest" ? "selected" : "" %>>Newest</option>
            </select>
        </div>

        <button class="btn btn-danger filter-action" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
            Search
        </button>

        <% if (searchValue || selectedCategory !== "all" || minValue || maxValue || selectedSort) { %>
            <a href="/listings" class="btn btn-outline-secondary filter-reset">Reset</a>
        <% } %>
    </form>
</section>

<section class="quick-categories" aria-label="Popular categories">
    <% const quickCategories = [
        ["all", "fa-fire", "Trending"],
        ["rooms", "fa-bed", "Rooms"],
        ["iconic cities", "fa-city", "Cities"],
        ["mountains", "fa-mountain", "Mountains"],
        ["castles", "fa-fort-awesome", "Castles"],
        ["amazing pool", "fa-person-swimming", "Pools"],
        ["camping", "fa-campground", "Camping"],
        ["farms", "fa-tractor", "Farms"],
        ["arctic", "fa-snowflake", "Arctic"],
        ["domes", "fa-igloo", "Domes"],
        ["ships", "fa-ship", "Ships"]
    ]; %>
    <% for (let item of quickCategories) { %>
        <a class="quick-category <%= selectedCategory === item[0] ? "active" : "" %>" href="/listings<%= item[0] === "all" ? "" : `?category=${encodeURIComponent(item[0])}` %>">
            <i class="fa-solid <%= item[1] %>"></i>
            <span><%= item[2] %></span>
        </a>
    <% } %>
</section>

<div class="results-meta">
    <p>
        <strong><%= listings.length %></strong>
        <%= listings.length === 1 ? "stay" : "stays" %> found
        <% if (searchValue) { %>
            for "<%= searchValue %>"
        <% } %>
    </p>
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="flexSwitchCheckReverse">
        <label class="form-check-label" for="flexSwitchCheckReverse">Show total with GST</label>
    </div>
</div>

<div class="listing-grid">
    <% if (listings.length === 0) { %>
        <div class="empty-state">
            <i class="fa-regular fa-compass"></i>
            <h3>No listings found</h3>
            <p>Try a different destination, category, or price range.</p>
            <a href="/listings" class="btn btn-dark">View all listings</a>
        </div>
    <% } else { %>
        <% for (let listing of listings) { %>
            <% const ratingCount = listing.reviews ? listing.reviews.length : 0; %>
            <% const avgRating = ratingCount ? (listing.reviews.reduce((sum, review) => sum + review.rating, 0) / ratingCount).toFixed(1) : null; %>
            <% const totalPrice = listing.price ? Math.round(listing.price * 1.18).toLocaleString("en-IN") : null; %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <article class="listing-card">
                    <div class="listing-image-wrap">
                        <img src="<%= listing.image && listing.image.url ? listing.image.url : "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=80" %>" class="card-img-top" alt="<%= listing.title %>">
                        <% if (listing.category) { %>
                            <span class="category-pill"><%= listing.category %></span>
                        <% } %>
                    </div>
                    <div class="listing-card-body">
                        <div>
                            <h2><%= listing.title %></h2>
                            <p class="listing-location">
                                <i class="fa-solid fa-location-dot"></i>
                                <%= listing.location %><%= listing.country ? `, ${listing.country}` : "" %>
                            </p>
                        </div>
                        <div class="rating-chip">
                            <i class="fa-solid fa-star"></i>
                            <span><%= avgRating || "New" %></span>
                        </div>
                    </div>
                    <div class="listing-price-row">
                        <p>
                            <% if (listing.price) { %>
                                <strong>₹<%= listing.price.toLocaleString("en-IN") %></strong>
                                <span>/ night</span>
                                <span class="text-info gst-total">₹<%= totalPrice %> incl. GST</span>
                            <% } else { %>
                                <strong>Price on request</strong>
                            <% } %>
                        </p>
                        <span><%= ratingCount %> <%= ratingCount === 1 ? "review" : "reviews" %></span>
                    </div>
                </article>
            </a>
        <% } %>
    <% } %>
</div>
