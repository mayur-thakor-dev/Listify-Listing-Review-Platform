<% layout("/layouts/boilerplate.ejs") %>
<% const reviewCount = listing.reviews ? listing.reviews.length : 0; %>
<% const avgRating = reviewCount ? (listing.reviews.reduce((sum, review) => sum + review.rating, 0) / reviewCount).toFixed(1) : null; %>
<% const totalPrice = listing.price ? Math.round(listing.price * 1.18).toLocaleString("en-IN") : null; %>

<section class="show-shell">
  <div class="show-hero">
    <div>
      <p class="section-kicker"><%= listing.category || "Stay" %></p>
      <h1 class="show-title"><%= listing.title %></h1>
      <div class="show-meta">
        <span><i class="fa-solid fa-location-dot"></i> <%= listing.location %><%= listing.country ? `, ${listing.country}` : "" %></span>
        <span><i class="fa-solid fa-star"></i> <%= avgRating || "New" %> · <%= reviewCount %> <%= reviewCount === 1 ? "review" : "reviews" %></span>
        <span><i class="fa-solid fa-user"></i> Hosted by <%= listing.owner.username %></span>
      </div>

      <img src="<%= listing.image.url %>" class="show-img" alt="<%= listing.title %>">

      <div class="show-panel mt-4">
        <h3>About this place</h3>
        <p><%= listing.description %></p>

        <div class="detail-list">
          <div class="detail-item">
            <i class="fa-solid fa-tag"></i>
            <p><strong>Category</strong><br><%= listing.category || "General stay" %></p>
          </div>
          <div class="detail-item">
            <i class="fa-solid fa-map-location-dot"></i>
            <p><strong>Location</strong><br><%= listing.location %><%= listing.country ? `, ${listing.country}` : "" %></p>
          </div>
          <div class="detail-item">
            <i class="fa-solid fa-shield-heart"></i>
            <p><strong>Guest confidence</strong><br>Reviews and owner controls are enabled for this listing.</p>
          </div>
        </div>
      </div>

      <div class="show-panel mt-4">
        <h3>Map location</h3>
        <div id="map"></div>
      </div>
    </div>

    <aside class="show-panel booking-summary">
      <p class="mb-1">Starting from</p>
      <% if (listing.price) { %>
        <div class="booking-price">₹<%= listing.price.toLocaleString("en-IN") %></div>
        <p class="text-muted">₹<%= totalPrice %> including 18% GST</p>
      <% } else { %>
        <div class="booking-price">Price on request</div>
        <p class="text-muted">Host has not shared nightly pricing.</p>
      <% } %>

      <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
        <div class="d-grid gap-2 mt-3">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger">
            <i class="fa-solid fa-pen"></i> Edit Listing
          </a>
          <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
            <button type="submit" class="btn btn-outline-danger w-100">
              <i class="fa-solid fa-trash"></i> Delete Listing
            </button>
          </form>
        </div>
      <% } else { %>
        <a href="#reviews" class="btn btn-dark w-100 mt-3">View Reviews</a>
      <% } %>
    </aside>
  </div>

  <div class="show-panel mt-4" id="reviews">
    <% if(currUser) { %>
      <h3>Leave a review</h3>
      <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
        <fieldset class="starability-slot">
          <legend>Rating:</legend>
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
          <input type="radio" id="second-rate1" name="review[rating]" value="1" />
          <label for="second-rate1" title="Terrible">1 star</label>
          <input type="radio" id="second-rate2" name="review[rating]" value="2" />
          <label for="second-rate2" title="Not good">2 stars</label>
          <input type="radio" id="second-rate3" name="review[rating]" value="3" />
          <label for="second-rate3" title="Average">3 stars</label>
          <input type="radio" id="second-rate4" name="review[rating]" value="4" />
          <label for="second-rate4" title="Very good">4 stars</label>
          <input type="radio" id="second-rate5" name="review[rating]" value="5" />
          <label for="second-rate5" title="Amazing">5 stars</label>
        </fieldset>

        <div class="mb-3">
          <label for="comment" class="form-label">Comments</label>
          <textarea name="review[comment]" id="comment" rows="4" class="form-control" required></textarea>
          <div class="invalid-feedback">Please enter your comments</div>
        </div>
        <button class="btn btn-outline-dark">Submit Review</button>
      </form>
      <hr>
    <% } %>

    <div class="d-flex align-items-center justify-content-between mb-3">
      <h3 class="mb-0">Reviews</h3>
      <span class="rating-chip"><i class="fa-solid fa-star"></i> <%= avgRating || "New" %></span>
    </div>

    <% if (reviewCount === 0) { %>
      <p class="text-muted mb-0">No reviews yet. Be the first to share your experience.</p>
    <% } else { %>
      <div class="row g-3">
        <% for(review of listing.reviews) { %>
          <div class="col-12 col-md-6">
            <div class="review-card p-3 h-100">
              <div class="d-flex align-items-start justify-content-between">
                <p class="review-author mb-1">@<%= review.author.username %></p>
                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
              </div>
              <p class="mb-2"><%= review.comment %></p>
              <% if(currUser && currUser._id.equals(review.author._id)) { %>
                <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-sm btn-outline-dark">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</section>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
  const coordinates = <%- JSON.stringify(listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates : []) %>;
  const locationName = <%- JSON.stringify(listing.location) %>;

  if (coordinates.length === 2) {
    const map = L.map("map").setView([coordinates[1], coordinates[0]], 13);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "&copy; OpenStreetMap contributors"
    }).addTo(map);

    L.marker([coordinates[1], coordinates[0]]).addTo(map)
      .bindPopup(`<b>${locationName}</b>`)
      .openPopup();
  } else {
    document.getElementById("map").innerHTML = "<p class='text-muted p-3'>Map is unavailable for this listing.</p>";
  }
</script>
